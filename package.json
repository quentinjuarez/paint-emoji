{
  "name": "paint-emoji",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,vue,css,md,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "oxlint": "^1.57.0",
    "oxlint-tailwindcss": "^0.1.10",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.21"
  },
  "packageManager": "yarn@3.8.6",
  "dependencies": {
    "@oxlint/binding-darwin-arm64": "^1.57.0",
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.12"
  }
}
