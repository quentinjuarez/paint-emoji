{
  "compilerOptions": {
    "target": "ES2021",
    "useDefineForClassFields": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "types": ["vite/client"],
    "strict": true,
    "erasableSyntaxOnly": true,
    "paths": {
      "@ui/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "../shared/src/types/auto-imports.d.ts", "../shared/src/types/components.d.ts"]
}
